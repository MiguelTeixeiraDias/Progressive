      "themeColor": "#0B0F14",
      "backgroundColor": "#0B0F14",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "690dfa06-12a9-44b0-9aa3-047d2d67d452"
      }
    },
    "owner": "migueltdias"
  }
